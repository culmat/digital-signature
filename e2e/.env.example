# E2E Test Configuration
# Copy this file to .env and fill in your values

# Confluence instance host (required)
CONFLUENCE_HOST=your-instance.atlassian.net

# Confluence API credentials (optional - falls back to FORGE_EMAIL/FORGE_API_TOKEN)
# Get API token from: https://id.atlassian.com/manage-profile/security/api-tokens
# If not set here, will use FORGE_EMAIL/FORGE_API_TOKEN from environment
# CONFLUENCE_EMAIL=your-email@example.com
# CONFLUENCE_API_TOKEN=your-api-token

# Space key for test pages (required)
TEST_SPACE=TEST

# Forge environment ID (required for macro storage format)
# Run: forge environments list
# Use the DEVELOPMENT environment ID
FORGE_ENV_ID=your-forge-environment-id

# Chrome DevTools Protocol endpoint (optional, default: http://localhost:9222)
CDP_ENDPOINT=http://localhost:9222

# Empty group ID for authorization testing (required for authorization tests)
# This should be a group that the test user is NOT a member of
# TEST_EMPTY_GROUP_ID=your-empty-group-id

# ── CMA end-to-end migration test (scripts/cma-e2e-test.sh) ──────────────────
# The local Confluence Server/DC base URL (Docker via legacy test-plugin.sh).
# Port is derived from the Confluence major version: V9 → 9090, V10 → 10090.
SERVER_BASE_URL=http://localhost:9090
SERVER_USER=admin
SERVER_PASS=admin
# Docker Confluence version started by the legacy test-plugin.sh
CONFLUENCE_VERSION=9.5.4
# Path to the legacy Server plugin repo (default: ../digital-signature-legacy)
# LEGACY_DIR=/absolute/path/to/digital-signature-legacy
# Space-key prefix; each run appends a timestamp for a fresh, independent space
MIGRATION_SPACE_PREFIX=CMA
# Forge environment the migration targets and is verified in. MUST be development.
# For this flow FORGE_ENV_ID (above) must be the DEVELOPMENT environment id.
FORGE_DEV_ENV=development
# Migration driving: 1 = attempt to drive the CMA wizard (falls back to manual on
# failure). Set CMA_MANUAL_MIGRATE=1 to always use the manual checkpoint.
CMA_AUTOMATE_MIGRATE=1
